{
  "root": "page",
  "enums": {
    "space":          { "prefix": "Space",    "values": ["none", "xs", "sm", "md", "lg", "xl"] },
    "align":          { "prefix": "Align",    "values": ["start", "center", "end", "stretch"] },
    "justify":        { "prefix": "Justify",  "values": ["start", "center", "end", "between"] },
    "button-kind":    { "prefix": "",         "values": ["primary", "ghost", "danger", "secondary"] },
    "page-kind":      { "prefix": "Page",     "values": ["sheet", "full"] },
    "form-dir":       { "prefix": "Dir",      "values": ["row", "col"] },
    "editor-kind":    { "prefix": "Editor",   "values": ["plain"] },
    "checkbox-kind":  { "prefix": "Check",    "values": ["plain"] },
    "modal-variant":  { "prefix": "ModalVar", "values": ["plain", "lists", "sizes", "wide"] },
    "mount-kind":     { "prefix": "Mount",    "values": [] }
  },
  "universal": [
    { "name": "id" },
    { "name": "title" },
    { "name": "hidden", "kind": "bare" },
    { "name": "grow", "kind": "bare" }
  ],
  "propPatterns": ["data-*", "aria-*"],
  "primitives": [
    { "name": "page",
      "props": [
        { "name": "title", "required": true },
        { "name": "kind", "enum": "page-kind" },
        { "name": "scripts" },
        { "name": "classicscripts" }
      ],
      "children": "any" },

    { "name": "topbar",
      "placement": "header",
      "props": [
        { "name": "title", "required": true },
        { "name": "titleid" },
        { "name": "home" },
        { "name": "nosync", "kind": "bare" },
        { "name": "syncstate" }
      ],
      "children": ["iconbtn", "iconlink"] },

    { "name": "iconbtn",
      "props": [ { "name": "label", "required": true }, { "name": "badgeid" } ],
      "children": "text" },

    { "name": "iconlink",
      "props": [ { "name": "href", "required": true }, { "name": "label", "required": true } ],
      "children": "text" },

    { "name": "col",
      "props": [
        { "name": "gap", "enum": "space" }, { "name": "align", "enum": "align" },
        { "name": "justify", "enum": "justify" }, { "name": "wrap", "kind": "bare" }
      ],
      "children": "any" },

    { "name": "row",
      "props": [
        { "name": "gap", "enum": "space" }, { "name": "align", "enum": "align" },
        { "name": "justify", "enum": "justify" }, { "name": "wrap", "kind": "bare" }
      ],
      "children": "any" },

    { "name": "spacer", "props": [], "children": "none" },
    { "name": "section", "props": [], "children": "any" },

    { "name": "text", "props": [], "children": "text" },
    { "name": "hint", "props": [], "children": "text" },
    { "name": "subhead", "props": [], "children": "text" },
    { "name": "empty", "props": [], "children": "text" },
    { "name": "label", "props": [{ "name": "for" }], "children": "text" },
    { "name": "bigcode", "props": [], "children": "none" },
    { "name": "message", "props": [], "children": "none" },
    { "name": "strong", "props": [], "inline": true, "children": "text" },
    { "name": "code", "props": [], "inline": true, "children": "text" },
    { "name": "muted", "props": [], "inline": true, "children": "text" },

    { "name": "form",
      "props": [
        { "name": "dir", "enum": "form-dir" }, { "name": "gap", "enum": "space" },
        { "name": "autocomplete" }, { "name": "method" }, { "name": "action" }
      ],
      "children": "any" },

    { "name": "textfield",
      "props": [
        { "name": "name" }, { "name": "placeholder" }, { "name": "autocomplete" },
        { "name": "spellcheck" }, { "name": "autocapitalize" }, { "name": "autocorrect" },
        { "name": "required", "kind": "bare" }, { "name": "autofocus", "kind": "bare" },
        { "name": "value" }, { "name": "maxlength" }, { "name": "minlength" }, { "name": "inputmode" },
        { "name": "pattern" }, { "name": "list" },
        { "name": "readonly", "kind": "bare" }, { "name": "disabled", "kind": "bare" }
      ],
      "children": "none" },

    { "name": "password",
      "props": [
        { "name": "name" }, { "name": "placeholder" }, { "name": "autocomplete" },
        { "name": "spellcheck" }, { "name": "autocapitalize" }, { "name": "autocorrect" },
        { "name": "required", "kind": "bare" }, { "name": "autofocus", "kind": "bare" },
        { "name": "value" }, { "name": "maxlength" }, { "name": "minlength" }, { "name": "inputmode" },
        { "name": "pattern" },
        { "name": "readonly", "kind": "bare" }, { "name": "disabled", "kind": "bare" }
      ],
      "children": "none" },

    { "name": "filefield",
      "props": [{ "name": "accept" }, { "name": "required", "kind": "bare" }],
      "children": "none" },

    { "name": "hiddenfield",
      "props": [{ "name": "name" }, { "name": "value" }],
      "children": "none" },

    { "name": "numfield",
      "props": [
        { "name": "min" }, { "name": "max" }, { "name": "step" },
        { "name": "placeholder" }, { "name": "narrow", "kind": "bare" }
      ],
      "children": "none" },

    { "name": "colorfield", "props": [{ "name": "value" }], "children": "none" },

    { "name": "sliderrow",
      "props": [
        { "name": "id", "required": true }, { "name": "label", "required": true },
        { "name": "valueid", "required": true },
        { "name": "min" }, { "name": "max" }, { "name": "step" }, { "name": "hint" }
      ],
      "children": "none" },

    { "name": "checkbox",
      "props": [{ "name": "kind", "enum": "checkbox-kind" }, { "name": "checked", "kind": "bare" }],
      "children": "text" },

    { "name": "radio",
      "props": [
        { "name": "name", "required": true }, { "name": "value", "required": true },
        { "name": "checked", "kind": "bare" }
      ],
      "children": "text" },

    { "name": "selectfield",
      "props": [{ "name": "name" }, { "name": "compact", "kind": "bare" }],
      "children": ["option"] },

    { "name": "option",
      "props": [{ "name": "value", "required": true }, { "name": "selected", "kind": "bare" }],
      "children": "text" },

    { "name": "editor",
      "props": [
        { "name": "kind", "enum": "editor-kind" }, { "name": "placeholder" },
        { "name": "spellcheck" }, { "name": "rows" }, { "name": "readonly", "kind": "bare" },
        { "name": "name" }, { "name": "required", "kind": "bare" }
      ],
      "children": "text" },

    { "name": "button",
      "props": [
        { "name": "kind", "enum": "button-kind" }, { "name": "small", "kind": "bare" },
        { "name": "submit", "kind": "bare" }, { "name": "disabled", "kind": "bare" },
        { "name": "href" }, { "name": "download", "kind": "bare" },
        { "name": "formaction" }, { "name": "formnovalidate", "kind": "bare" },
        { "name": "name" }, { "name": "value" }
      ],
      "children": "text" },

    { "name": "field", "props": [{ "name": "label", "required": true }], "children": "any" },
    { "name": "unreaddot", "props": [], "inline": true, "children": "none" },

    { "name": "modal",
      "placement": "overlay",
      "props": [
        { "name": "id", "required": true }, { "name": "label", "required": true },
        { "name": "title" }, { "name": "done" }, { "name": "doneid" },
        { "name": "variant", "enum": "modal-variant" }
      ],
      "children": "any" },

    { "name": "dialog",
      "props": [{ "name": "open", "kind": "bare" }],
      "children": "any" },

    { "name": "tabs", "props": [], "children": ["tab"] },
    { "name": "tab", "props": [{ "name": "view", "required": true }], "children": "text" },
    { "name": "tabpanel", "props": [], "children": "any" },

    { "name": "details", "props": [{ "name": "open", "kind": "bare" }], "children": "any" },
    { "name": "summary", "props": [], "children": "text" },
    { "name": "fieldset", "props": [], "children": "any" },
    { "name": "datalist", "props": [], "children": ["option"] },

    { "name": "list", "props": [], "children": ["listrow"] },
    { "name": "listrow", "props": [{ "name": "href" }], "children": "any" },
    { "name": "listtitle", "props": [], "children": "text" },

    { "name": "table", "props": [{ "name": "scroll", "kind": "bare" }], "children": ["trow"] },
    { "name": "trow", "props": [], "children": ["hcell", "cell"] },
    { "name": "hcell", "props": [], "children": "content" },
    { "name": "cell", "props": [], "children": "content" },

    { "name": "mount", "props": [{ "name": "kind", "enum": "mount-kind", "required": true }], "children": "any" }
  ]
}
