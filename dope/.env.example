# Copy to .env and fill in. .env is gitignored.

# Token from @BotFather. Required for the bot to leave stub mode.
TELEGRAM_BOT_TOKEN=

# Optional: override the SQLite file used by both the web server and the bot.
# Default is ./tournament.db relative to the working directory.
# DOPE_DB=tournament.db

# Optional: bot username shown on /register. Default is dope_pecheny_bot.
# Set this if the TELEGRAM_BOT_TOKEN above points at a different bot.
# DOPE_BOT_NAME=dope_pecheny_bot

# Optional: set to "production" to mark the session cookie as Secure.
# DOPE_ENV=

# Optional: HTTP port for the web server (default 8080).
# PORT=8080

# Optional: deployment target used by `just deploy`.
# DOPE_DEPLOY_HOST=vps2day-ee
# DOPE_DEPLOY_DIR=/opt/dope
# DOPE_DEPLOY_SERVICE=dope.service
# DOPE_DEPLOY_ARCH=amd64
