# Copy to .env and fill in. .env is gitignored.

# Token from @BotFather. Required for Telegram login-code delivery and for the bot to leave stub mode.
TELEGRAM_BOT_TOKEN=

# Optional: override the SQLite file used by both the web server and the bot.
# Default is ./fest.db relative to the working directory.
# DOPE_DB=fest.db

# Optional: login bot @handle, for the t.me deep link the login page offers.
# Default is dope_pecheny_bot. Set this if the token above points at another bot.
# DOPE_BOT_NAME=dope_pecheny_bot

# The session cookie is marked Secure (HTTPS-only) by default; set this to
# "development" to drop Secure for plaintext-HTTP local dev over a non-localhost
# host. Leave unset in production.
DOPE_ENV=development

# Optional: HTTP port for the web server (default 8080).
# PORT=8080

# Optional: deployment target used by `just deploy`.
# DOPE_DEPLOY_HOST=vps2day-ee
# DOPE_DEPLOY_DIR=/opt/dope
# DOPE_DEPLOY_SERVICE=dope.service
# DOPE_DEPLOY_ARCH=amd64
