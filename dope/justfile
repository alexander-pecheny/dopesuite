set dotenv-load := true

default: dev

web:
    go run .

bot:
    go run ./cmd/telegram-bot

dev:
    #!/usr/bin/env bash
    set -euo pipefail
    trap 'kill 0' EXIT INT TERM
    go run . &
    go run ./cmd/telegram-bot &
    wait

# Mint a one-shot invite code and print it. Reads DOPE_DB from .env.
# Usage: just invite [days]
invite days='7':
    uv run python scripts/mint_invite.py {{days}}

# Seed an existing tournament with the bundled studchr scheme.
# Usage: DOPE_SESSION=<session-cookie-value> just seed <tournament_id>
seed tournament_id:
    #!/usr/bin/env bash
    set -euo pipefail
    : "${DOPE_SESSION:?set DOPE_SESSION to an organizer session cookie value}"
    curl -s -X POST -H "Content-Type: application/json" \
      --cookie "session=${DOPE_SESSION}" \
      --data-binary @static/schemes/studchr-ek-2026.json \
      "http://localhost:8080/api/import?tournament_id={{tournament_id}}" > /dev/null && echo seeded
