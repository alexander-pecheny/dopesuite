# xy server + bot configuration. Copy to .env (loaded by just via dotenv-load).

# HTTP port for the server (default 9673).
PORT=9673

# SQLite database path (default xy.db in the working directory).
XY_DB=xy.db

# Set to "production" to mark the session cookie Secure (HTTPS only).
XY_ENV=development

# docx export, import and handout PDFs are all fully in-process Go — xy has no
# external runtime dependencies at all. typst is linked in as a WebAssembly module
# (fonts and templates embedded in the binary), so the typst binary is NOT needed
# on the host.
#
# XY_WASM_CACHE is where wazero keeps typst compiled to machine code. It must be on
# PERSISTENT storage: compiling it takes ~15s cold but ~0.5s from the cache, and the
# cache survives restarts — put it on tmpfs and every reboot pays the 15s again. It
# holds compiled typst, never user data. Defaults to $XDG_CACHE_HOME/xy/typst-wasm.
# XY_WASM_CACHE=/var/lib/xy/typst-wasm

# Shared secret between the server and the telegram bot. Must match on both.
# Generate with: openssl rand -hex 32
XY_BOT_SECRET=

# Telegram bot (cmd/telegram-bot) only:
XY_BOT_TOKEN=
XY_SERVER_URL=http://localhost:9673

# `just deploy` (deploy.py): ssh target of the VPS. The other deploy knobs
# (XY_DEPLOY_DIR/DATA/SERVICE/BOT) have working defaults — see deploy.py.
XY_DEPLOY_HOST=

# XY_SCRATCH_DIR is now only used by the typst CLI typesetter, which is kept as a
# test oracle and is not on any request path — the server renders handouts through
# the in-memory wasm typst, which writes nothing at all.
# XY_SCRATCH_DIR=/dev/shm
