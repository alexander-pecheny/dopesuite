# xy server + bot configuration. Copy to .env (loaded by just via dotenv-load).

# HTTP port for the server (default 9673).
PORT=9673

# SQLite database path (default xy.db in the working directory).
XY_DB=xy.db

# Set to "production" to mark the session cookie Secure (HTTPS only).
XY_ENV=development

# Command used by the "export list to docx" and "генерация раздаток" features.
# The server appends `compose docx source.4s` (docx) or `handouts hndt2pdf
# source.hndt` (handout PDFs) and runs it in a scratch dir. Requires chgksuite
# (pip install chgksuite). The handout-PDF path additionally renders LaTeX via
# `tectonic`; chgksuite auto-installs it on first run (≈150 MB, needs network),
# so pre-install tectonic on the host to avoid a slow first generation.
# Space-separated; default "chgksuite". Venv example:
# XY_CHGKSUITE_CMD=/opt/xy/venv/bin/chgksuite
XY_CHGKSUITE_CMD=chgksuite

# Shared secret between the server and the telegram bot. Must match on both.
# Generate with: openssl rand -hex 32
XY_BOT_SECRET=

# Telegram bot (cmd/telegram-bot) only:
XY_BOT_TOKEN=
XY_SERVER_URL=http://localhost:9673
