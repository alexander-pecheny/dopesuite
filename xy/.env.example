# xy server + bot configuration. Copy to .env (loaded by just via dotenv-load).

# HTTP port for the server (default 9673).
PORT=9673

# SQLite database path (default xy.db in the working directory).
XY_DB=xy.db

# Set to "production" to mark the session cookie Secure (HTTPS only).
XY_ENV=development

# docx export ("export list to docx") is fully in-process Go — no config needed.
# Handout PDFs ("генерация раздаток") are typeset with the standalone `typst`
# binary; the only external runtime dependency. Point at it with XY_TYPST_CMD
# (default "typst"). Fonts and templates are embedded in the server binary.
XY_TYPST_CMD=typst

# Shared secret between the server and the telegram bot. Must match on both.
# Generate with: openssl rand -hex 32
XY_BOT_SECRET=

# Telegram bot (cmd/telegram-bot) only:
XY_BOT_TOKEN=
XY_SERVER_URL=http://localhost:9673

# `just deploy` (deploy.py): ssh target of the VPS. The other deploy knobs
# (XY_DEPLOY_DIR/DATA/SERVICE/BOT) have working defaults — see deploy.py.
XY_DEPLOY_HOST=

# Handout rendering is the one place xy must materialise plaintext on a filesystem
# (typst is a separate process and cannot read from memory). The scratch dir is
# wiped when the render returns; point it at a RAM-backed path so a crash can't
# leave decrypted questions on persistent storage. Defaults to /dev/shm when it is
# usable, else the OS temp dir.
# XY_SCRATCH_DIR=/dev/shm
