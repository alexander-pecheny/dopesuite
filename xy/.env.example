# xy server + bot configuration. Copy to .env (loaded by just via dotenv-load).

# HTTP port for the server (default 9673).
PORT=9673

# SQLite database path (default xy.db in the working directory).
XY_DB=xy.db

# Set to "production" to mark the session cookie Secure (HTTPS only).
XY_ENV=development

# Command used by the "export list to docx" feature. The server appends
# `compose docx source.4s` and runs it in a scratch dir. Requires chgksuite to
# be installed (pip install chgksuite). Space-separated; default "chgksuite".
# Example for a venv: XY_CHGKSUITE_CMD=/opt/xy/venv/bin/chgksuite
XY_CHGKSUITE_CMD=chgksuite

# Shared secret between the server and the telegram bot. Must match on both.
# Generate with: openssl rand -hex 32
XY_BOT_SECRET=

# Telegram bot (cmd/telegram-bot) only:
XY_BOT_TOKEN=
XY_SERVER_URL=http://localhost:9673
